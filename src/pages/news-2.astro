---
import '../styles/global.css';
const instagramUrl = "https://www.instagram.com/aki.pickles/";
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>公式サイトを公開しました｜AKI PICKLES</title>
  <meta name="description" content="AKI PICKLES 公式サイトがオープンしました。広島県安芸郡府中町を拠点とするピックルボールクラブの活動情報を随時更新していきます。">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
</head>
<body style="background: #FAF4E8;">

<!-- ヘッダー -->
<header style="position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(250, 244, 232, 0.92); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(224, 96, 74, 0.14);">
  <div style="max-width: 1080px; margin: 0 auto; padding: 0 20px; height: 64px; display: flex; align-items: center; justify-content: space-between; gap: 16px;">
    <a href="/" style="display: flex; align-items: center; gap: 10px; text-decoration: none;">
      <img src="/logo.webp" alt="AKI PICKLES" style="height: 42px; width: auto; display: block; mix-blend-mode: multiply;">
      <span style="font-size: 11px; font-weight: 500; color: #A08F78; letter-spacing: 0.1em;">あきぴっくるず</span>
    </a>
    <a href="/" style="font-size: 13px; font-weight: 600; color: #E0604A; text-decoration: none; display: flex; align-items: center; gap: 6px;">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5 M11 6l-6 6 6 6"></path></svg>
      トップへ戻る
    </a>
  </div>
</header>

<!-- 記事 -->
<article style="padding: 110px 20px 80px;">
  <div style="max-width: 680px; margin: 0 auto; display: flex; flex-direction: column; gap: 32px;">

    <!-- ヘッダー情報 -->
    <div style="display: flex; flex-direction: column; gap: 16px;">
      <div style="display: flex; align-items: center; gap: 12px;">
        <time style="font-family: Jost, sans-serif; font-size: 13px; font-weight: 500; color: #A08F78; letter-spacing: 0.06em;">2026.07.01</time>
        <span style="font-size: 11px; font-weight: 700; color: #A08F78; background: #F3EBDC; padding: 3px 10px; border-radius: 999px; letter-spacing: 0.08em;">お知らせ</span>
      </div>
      <h1 style="margin: 0; font-size: clamp(22px, 5vw, 32px); font-weight: 900; color: #33291F; line-height: 1.5; letter-spacing: 0.02em;">
        AKI PICKLES 公式サイトを公開しました
      </h1>
    </div>

    <!-- 本文 -->
    <div style="background: #FFFFFF; border-radius: 16px; padding: 32px 28px; border: 1px solid rgba(160, 143, 120, 0.16); display: flex; flex-direction: column; gap: 20px;">
      <p style="margin: 0; font-size: 15px; line-height: 2; color: #4A3F34; font-weight: 500;">
        広島県安芸郡府中町を拠点とするピックルボールクラブ「AKI PICKLES（あきぴっくるず）」の公式サイトがオープンしました。
      </p>
      <p style="margin: 0; font-size: 15px; line-height: 2; color: #4A3F34; font-weight: 500;">
        サイトでは、クラブの活動情報・体験会スケジュール・活動場所などを随時更新していきます。最新情報は Instagram でも発信していますので、ぜひフォローしてください。
      </p>
      <p style="margin: 0; font-size: 15px; line-height: 2; color: #4A3F34; font-weight: 500;">
        これからどうぞよろしくお願いします！
      </p>
    </div>

    <!-- Instagram リンク -->
    <div style="display: flex; justify-content: center;">
      <a href={instagramUrl} target="_blank" rel="noopener" class="btn-outline"
        style="display: inline-flex; align-items: center; gap: 9px; font-size: 15px; font-weight: 700; color: #E0604A; background: #FFFFFF; border: 1.5px solid rgba(224, 96, 74, 0.4); text-decoration: none; padding: 14px 26px; border-radius: 999px; transition: border-color 0.2s, background 0.2s;">
        <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="0.6"></circle></svg>
        Instagram をフォローする
      </a>
    </div>

    <!-- 戻るリンク -->
    <a href="/#news" style="display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; color: #A08F78; text-decoration: none;">
      <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5 M11 6l-6 6 6 6"></path></svg>
      お知らせ一覧へ
    </a>
  </div>
</article>

<!-- フッター -->
<footer style="background: #33291F; color: #D8C7A8; padding: 28px 20px;">
  <div style="max-width: 1080px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap;">
    <span style="font-size: 11.5px; color: #A08F78;">© 2026 AKI PICKLES. All rights reserved.</span>
    <a href="/" style="font-size: 13px; font-weight: 600; color: #D8C7A8; text-decoration: none;">トップへ戻る</a>
  </div>
</footer>

</body>
</html>
