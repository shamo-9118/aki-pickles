      </div>
    </div>
  </div>
</section>

<!-- お問い合わせ -->
<section id="contact" style="padding: 84px 20px 96px; background: #FFFDF8;">
  <div style="max-width: 720px; margin: 0 auto; display: flex; flex-direction: column; gap: 36px;">
    <div style="display: flex; flex-direction: column; gap: 8px; text-align: center;">
      <span style="font-family: Jost, sans-serif; font-weight: 600; font-size: 12px; letter-spacing: 0.3em; color: #E0604A;">CONTACT</span>
      <h2 style="margin: 0; font-size: 27px; font-weight: 900; color: #33291F;">お問い合わせはこちら</h2>
      <p style="margin: 10px 0 0; font-size: 14px; line-height: 1.9; color: #6B5F4E;">体験会・見学のお申し込み、ご質問は Instagram の DM にてお気軽にどうぞ。</p>
    </div>
    <a href={instagramUrl} target="_blank" rel="noopener" class="btn-primary" style="align-self: center; display: inline-flex; align-items: center; gap: 10px; font-size: 16px; font-weight: 700; color: #FFFFFF; background: #E0604A; text-decoration: none; padding: 17px 34px; border-radius: 999px; box-shadow: 0 6px 18px rgba(224, 96, 74, 0.32); transition: background 0.2s, transform 0.2s;">
      <svg viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="0.6"></circle></svg>
      お問い合わせはこちら
    </a>
    <div style="display: flex; flex-direction: column; gap: 14px; margin-top: 8px;">
      <h3 style="margin: 0; font-size: 17px; font-weight: 700; color: #33291F;">よくある質問</h3>
      {faqs.map(faq => (
        <div class="faq-item" style="background: #FAF4E8; border-radius: 12px; overflow: hidden;">
          <button class="faq-summary" style="width: 100%; background: none; border: none; padding: 18px 22px; cursor: pointer; display: flex; align-items: center; gap: 10px; text-align: left;">
            <span style="font-family: Jost, sans-serif; font-weight: 700; font-size: 14px; color: #E0604A; flex-shrink: 0;">Q.</span>
            <span style="font-size: 14.5px; font-weight: 700; color: #33291F; line-height: 1.7; flex: 1;">{faq.q}</span>
            <svg class="faq-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#A08F78" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; transition: transform 0.35s ease;"><path d="M6 9l6 6 6-6"></path></svg>
          </button>
          <div class="faq-body">
            <div class="faq-inner">
              <div style="padding: 0 22px 18px; display: flex; gap: 10px; align-items: baseline;">
                <span style="font-family: Jost, sans-serif; font-weight: 700; font-size: 14px; color: #A08F78; flex-shrink: 0;">A.</span>
                <span style="font-size: 13.5px; color: #6B5F4E; line-height: 1.9;">{faq.a}</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- フッター -->
<footer style="background: #33291F; color: #D8C7A8; padding: 44px 20px 34px;">
  <div style="max-width: 1080px; margin: 0 auto; display: flex; flex-direction: column; gap: 24px;">
    <div style="display: flex; align-items: center; justify-content: space-between; gap: 18px; flex-wrap: wrap;">
      <div style="display: flex; flex-direction: column; gap: 4px;">
        <span style="font-family: Jost, sans-serif; font-weight: 700; font-size: 19px; letter-spacing: 0.08em; color: #FAF4E8;">AKI PICKLES</span>
        <span style="font-size: 12px; color: #A08F78;">ピックルボールクラブ あきぴっくるず ／ 広島県安芸郡府中町</span>
      </div>
      <a href={instagramUrl} target="_blank" rel="noopener" aria-label="Instagram" class="footer-ig" style="width: 44px; height: 44px; border-radius: 12px; background: rgba(250, 244, 232, 0.1); display: flex; align-items: center; justify-content: center; color: #FAF4E8; text-decoration: none; transition: background 0.2s;">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="0.6"></circle></svg>
      </a>
    </div>
    <div style="border-top: 1px solid rgba(250, 244, 232, 0.12); padding-top: 20px; display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap;">
      <span style="font-size: 11.5px; color: #A08F78;">© 2026 AKI PICKLES. All rights reserved.</span>
      <img src="/momiji.webp" alt="" width="16" height="16" style="opacity: 0.6;" />
    </div>
  </div>
</footer>

<script>
  // ローディング
  const loader = document.getElementById('loader');
  if (loader) {
    setTimeout(() => { loader.style.opacity = '0'; }, 2300);
    setTimeout(() => { loader.style.display = 'none'; }, 2900);
  }

  // ヒーロースライドショー
  const slides = document.querySelectorAll('.hero-slide');
  let heroIndex = 0;
  if (slides.length > 1) {
    setInterval(() => {
      slides[heroIndex].classList.remove('active');
      heroIndex = (heroIndex + 1) % slides.length;
      slides[heroIndex].classList.add('active');
    }, 5000);
  }

  // モバイルメニュー
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const desktopNav = document.getElementById('desktop-nav');

  const OPEN_PATH = "M6 6l12 12 M6 18L18 6";
  const CLOSE_PATH = "M4 7h16 M4 12h16 M4 17h16";

  function updateLayout() {
    const isMobile = window.matchMedia('(max-width: 767px)').matches;
    if (menuBtn) menuBtn.style.display = isMobile ? 'flex' : 'none';
    if (desktopNav) desktopNav.style.display = isMobile ? 'none' : 'flex';
    if (!isMobile && mobileMenu) {
      mobileMenu.classList.remove('open');
      if (menuIcon) menuIcon.setAttribute('d', CLOSE_PATH);
    }
  }

  updateLayout();
  window.matchMedia('(max-width: 767px)').addEventListener('change', updateLayout);

  if (menuBtn && mobileMenu && menuIcon) {
    menuBtn.addEventListener('click', () => {
      const isOpen = mobileMenu.classList.toggle('open');
      menuIcon.setAttribute('d', isOpen ? OPEN_PATH : CLOSE_PATH);
    });
  }

  // モバイルメニューのリンクをクリックしたら閉じる
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.remove('open');
      if (menuIcon) menuIcon.setAttribute('d', CLOSE_PATH);
    });
  });

  // FAQ アコーディオン（排他制御・アニメーション）
  const faqItems = document.querySelectorAll('.faq-item');
  faqItems.forEach(item => {
    const btn = item.querySelector('.faq-summary');
    btn?.addEventListener('click', () => {
      const isOpen = item.classList.contains('is-open');
      faqItems.forEach(i => i.classList.remove('is-open'));
      if (!isOpen) item.classList.add('is-open');
    });
  });
</script>

</body>
</html>
