        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7 M9 7h8v8"></path></svg>
      </a>
    </div>
  </div>
</section>

<!-- 活動予定 -->
<section id="schedule" style="padding: 84px 20px; background: #FFFDF8;">
  <div style="max-width: 880px; margin: 0 auto; display: flex; flex-direction: column; gap: 30px;">
    <div style="display: flex; flex-direction: column; gap: 8px;">
      <span style="font-family: Jost, sans-serif; font-weight: 600; font-size: 12px; letter-spacing: 0.3em; color: #E0604A;">SCHEDULE</span>
      <h2 style="margin: 0; font-size: 27px; font-weight: 900; color: #33291F;">活動予定</h2>
    </div>
    <div style="overflow-x: auto; border-radius: 14px; border: 1px solid rgba(160, 143, 120, 0.2); background: #FFFFFF;">
      <div style="min-width: 560px;">
        <div style="display: grid; grid-template-columns: 140px repeat(7, 1fr); background: #FFF9EF; border-bottom: 2px solid rgba(224, 96, 74, 0.25);">
          <div style="padding: 15px 18px; font-size: 13px; font-weight: 700; color: #A08F78;">時間帯</div>
          {scheduleDays.map(day => (
            <div style={`padding: 15px 8px; font-size: 14px; font-weight: 700; color: ${day.color}; text-align: center;`}>{day.label}</div>
          ))}
        </div>
        {scheduleRows.map(row => (
          <div style="display: grid; grid-template-columns: 140px repeat(7, 1fr); border-bottom: 1px solid rgba(160, 143, 120, 0.14);">
            <div style="padding: 17px 18px; font-family: Jost, sans-serif; font-size: 14px; font-weight: 600; color: #3C3630; white-space: nowrap; display: flex; align-items: center;">{row.time}</div>
            {row.marks.map((mark, i) => {
              const isActive = mark === "○";
              return (
                <div style={`padding: 17px 8px; display: flex; align-items: center; justify-content: center; font-size: ${isActive ? '18px' : '14px'}; font-weight: 700; color: ${isActive ? '#E0604A' : '#C9BCA4'}; background: ${isActive ? 'rgba(224, 96, 74, 0.07)' : 'transparent'};`}>{isActive ? '○' : '–'}</div>
              );
            })}
          </div>
        ))}
      </div>
    </div>
    <p style="margin: 0; font-size: 12.5px; color: #A08F78; line-height: 1.8;">{scheduleNote}</p>
  </div>
</section>

<!-- 活動場所 -->
